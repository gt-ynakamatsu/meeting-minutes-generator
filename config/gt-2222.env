# =============================================================================
# GT-2222 実機向け（docker ps / docker network に合わせた値）
# Ollama は本リポジトリの Compose では起動しません。別 Docker の Ollama が
# 外部ネットワーク llm-net に参加している前提です（例: コンテナ名 ollama-server）。
#
# 使い方:
#   cp config/gt-2222.env .env
#   docker network create llm-net   # 未作成時のみ
#   docker compose up -d --build
#
# Ollama が llm-net にいない場合は参加させる:
#   docker network connect llm-net ollama-server
#
# コンテナ名が違う場合は .env で上書き:
#   OLLAMA_BASE_URL=http://<コンテナ名>:11434
# =============================================================================
#
# --- 参考: 当時のコンテナ一覧 ---
#   ollama-server     llm-net 上・11434
#   whisper-ui        8085->8501 (Streamlit 旧 UI)
#   whisper-worker / meeting-minutes-generator-redis-1
#
# 8085 が旧 UI と重なる場合は whisper-ui を止めるか MM_FRONTEND_PORT を変更。
# 他サービスが使うポート例: 3000 5055 8083 8084 8100 8182 8502 …
# =============================================================================

COMPOSE_PROJECT_NAME=meeting-minutes-generator

MM_FRONTEND_PORT=8085

# HTTPS 公開時はブラウザのオリジン（パスなし）を必ず含める（ホスト名は社内 DNS で実際に引ける名前に合わせる）
MM_CORS_ORIGINS=http://localhost:8085,http://127.0.0.1:8085,http://gt-2222:8085,http://localhost:5173,https://gt-2222

# ホスト Nginx: https://gt-2222/meetingminutesnotebook/ → 127.0.0.1:8085 へ（パス剥がし）のとき frontend 再ビルド必須
VITE_BASE_PATH=/meetingminutesnotebook/
VITE_API_BASE=/meetingminutesnotebook

# フロントビルド時に埋め込み（通知案内の名前付き URL）。不要なら空
VITE_ALT_APP_HOSTNAME=gt-2222

WEBHOOK_URL=YOUR_WEBHOOK_URL_HERE

OLLAMA_BASE_URL=http://ollama-server:11434

# 認証（必須運用推奨）: ユーザーごとに議事録 DB を分離。未記載でも Compose 側フォールバックで ON になるが、本番は必ず独自値に（例: openssl rand -hex 32）
MM_AUTH_SECRET=meet-minutes-default-jwt-hs256-key-change-in-production-use-openssl-rand-hex-32

# 1人目以降の自己登録（既定 ON）。招待制にする場合は 0
MM_AUTH_SELF_REGISTER=1

# 議事録の自動削除（作成から N 日。待機・処理中は除く）。旧値 183 はアプリが 30 日として扱うが、明示的に 30 を推奨
MM_MINUTES_RETENTION_DAYS=30

# モデルは Ollama 側で pull（例: docker exec ollama-server ollama pull qwen2.5:7b）
