# --- ビルドコンテキストを小さくする（700MB+ 転送の主因を除外）---

# Git
.git
.gitignore
.gitattributes

# フロントは ./frontend を build context にした Dockerfile でビルド（ここではディレクトリごと除外）
frontend

# ホストに残った node_modules 等（ルート直下など）
**/node_modules
**/dist

# 実行時にボリュームマウントするデータ（DB・DL・ユーザー別 DB）
data
downloads

# Python キャッシュ・仮想環境
__pycache__
**/__pycache__
*.py[cod]
*$py.class
.venv
venv
ENV
.pytest_cache
.mypy_cache
.ruff_cache
*.egg-info
.eggs

# エディタ・OS
.idea
.vscode
.cursor
.DS_Store
Thumbs.db

# pipeline（worker / api イメージでは未使用）
pipeline

# ドキュメント・アーカイブ（イメージに不要）
document
archive
*.md

# 秘密・ローカル設定（イメージに含めない）
.env
.env.*
!.env.example
config/*.env

# デプロイ用シェル（イメージに不要）
scripts

# ログ・一時
*.log
tmp
temp
.cache

# 学習・モデル系（誤って置かれた場合の保険）
*.pt
*.pth
*.ckpt
*.bin
wandb
lightning_logs
