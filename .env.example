# 汎用テンプレ（GT-2222 では config/gt-2222.env をコピーする運用を推奨）
# cp .env.example .env
#
# 初回のみ（未作成時）: docker network create llm-net
# Ollama コンテナを llm-net に参加: docker network connect llm-net <コンテナ名>

# --- Docker Compose ---
# ブラウザで開くポート（ホスト側）
MM_FRONTEND_PORT=8085

# FastAPI の CORS（カンマ区切り。本番の公開 URL を追加）
MM_CORS_ORIGINS=http://localhost:8085,http://127.0.0.1:8085,http://localhost:5173

# ワーカーは llm-net 経由で Ollama に届く想定（既定: コンテナ名 ollama-server）
# OLLAMA_BASE_URL=http://ollama-server:11434

# --- faster-whisper（動画・音声の文字起こし。worker コンテナのみ）---
# 未指定時の既定は tasks.py / docker-compose（medium / cuda / float16）。通常は .env に書かなくてよい。
# VRAM 不足（CUDA out of memory）のときだけ例として追記:
# WHISPER_MODEL=small
# WHISPER_COMPUTE_TYPE=int8_float16
# 最終手段（遅い）: WHISPER_DEVICE=cpu  WHISPER_COMPUTE_TYPE=int8

# --- ホストで CLI パイプライン（pipeline/*.py）を動かす場合 ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# --- OpenAI / ChatGPT（課金 API。無効化する場合は 0）---
# 未設定時は「有効」（既存の非 Docker 運用の後方互換）。Docker Compose 既定は .yml 側で 0。
# MM_OPENAI_ENABLED=0
# MM_OPENAI_ENABLED=1

# --- Celery（compose 外で API だけ起動するときなど）---
# CELERY_BROKER_URL=redis://localhost:6379/0

# --- フロント開発（Vite）---
# リポジトリ直下 .env に書く（frontend/ ではなくルート）。既定 http://127.0.0.1:8000
# VITE_DEV_API_PROXY=http://127.0.0.1:8000
# 任意: 通知案内に「名前で開く URL」を追加（例: 社内ホスト名。Docker では frontend 再ビルドで反映）
# VITE_ALT_APP_HOSTNAME=gt-2222
# 任意: サブパス配信（例: https://host/meetingminutesnotebook/）。Docker frontend 再ビルド必須。VITE_API_BASE は末尾スラッシュなし推奨
# VITE_BASE_PATH=/meetingminutesnotebook/
# VITE_API_BASE=/meetingminutesnotebook

# --- 通知（ワーカー・旧 Streamlit 共通のプレースホルダ差し替え）---
# WEBHOOK_URL=

# メール完了通知（当面デフォルトオフ。有効にする: MM_EMAIL_NOTIFY_ENABLED=1 と下記 SMTP を両方設定）
# MM_EMAIL_NOTIFY_ENABLED=1
# 送信は Celery ワーカー。API は検証のためワーカーと同じ SMTP 変数を api サービスにも渡すこと。
# MM_SMTP_HOST=smtp.example.com
# MM_SMTP_PORT=587
# MM_SMTP_FROM=noreply@example.com
# MM_SMTP_USER=
# MM_SMTP_PASSWORD=
# 465 のときは SSL、587 では既定で STARTTLS。無効にする: MM_SMTP_STARTTLS=0

# 認証 ON 時: data/registry.db（ユーザー・OpenAI キー）、data/user_data/<ユーザー別>/minutes.db（議事録）
# 認証 OFF 時: data/minutes.db のみ（全員で共有 — 複数ユーザー運用では非推奨）

# --- API ログイン（Compose 既定で認証 ON。未指定時は docker-compose.yml のフォールバック秘密鍵が使われます）---
# 本番・外部公開では必ず独自の長いランダム文字列に（例: openssl rand -hex 32）
# MM_AUTH_SECRET=your-secret-here
# 初回のみ（users が空）: ブラウザの「初回セットアップ」で管理者を作成可能。または下記で API 起動時に自動登録:
# MM_BOOTSTRAP_ADMIN_USER=admin
# MM_BOOTSTRAP_ADMIN_PASSWORD=change-me
# JWT 有効時間（時間単位、既定 168 = 7 日）
# MM_AUTH_TOKEN_HOURS=168
# 1人目以降の自己登録（既定 ON = 1）。0 / false で無効（管理者の追加のみ）
MM_AUTH_SELF_REGISTER=1
